<Window x:Class="InventoryManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет ТМЦ" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#F0F0F0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Margin="5">
                <TextBlock Text="Категории" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="CategoryNameBox" Margin="0,0,0,5"/>
                <Button Content="Добавить категорию" Click="AddCategoryBtn_Click" Height="25"/>
            </StackPanel>

            <ListBox x:Name="CategoryListBox" Grid.Row="1" Margin="5"
                     DisplayMemberPath="Name"
                     SelectionChanged="CategoryListBox_SelectionChanged"/>
        </Grid>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Добавить товар">
                <StackPanel Margin="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center"/>
                        <TextBox x:Name="ProductNameBox" Grid.Row="0" Grid.Column="1" Margin="5,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="SKU:" VerticalAlignment="Center"/>
                        <TextBox x:Name="ProductSKUBox" Grid.Row="1" Grid.Column="1" Margin="5,2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Количество:" VerticalAlignment="Center"/>
                        <TextBox x:Name="ProductQuantityBox" Grid.Row="2" Grid.Column="1" Margin="5,2"/>
                    </Grid>
                    <Button Content="Добавить товар" Click="AddProductBtn_Click" Height="25" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <ListView x:Name="ProductsListBox" Grid.Row="1"
                      SelectionChanged="ProductsListBox_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Название" Width="200" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="SKU" Width="100" DisplayMemberBinding="{Binding SKU}"/>
                        <GridViewColumn Header="Остаток" Width="80" DisplayMemberBinding="{Binding Quantity}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <GroupBox Grid.Row="2" Header="Движение товара">
                <StackPanel Margin="5">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <RadioButton x:Name="RadioIn" Content="Приход" IsChecked="True" Margin="0,0,10,0"/>
                        <RadioButton x:Name="RadioOut" Content="Расход"/>
                    </StackPanel>
                    <TextBlock Text="Количество:"/>
                    <TextBox x:Name="MovementQuantityBox" Margin="0,5"/>
                    <TextBlock Text="Комментарий:"/>
                    <TextBox x:Name="MovementCommentBox" Margin="0,5"/>
                    <Button Content="Выполнить операцию" Click="AddMovementBtn_Click" Height="25" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <ListView x:Name="MovementsListBox" Grid.Row="3">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Дата" Width="120" DisplayMemberBinding="{Binding Date, StringFormat='dd.MM.yyyy HH:mm'}"/>
                        <GridViewColumn Header="Тип" Width="70" DisplayMemberBinding="{Binding Type}"/>
                        <GridViewColumn Header="Кол-во" Width="70" DisplayMemberBinding="{Binding Quantity}"/>
                        <GridViewColumn Header="Комментарий" Width="200" DisplayMemberBinding="{Binding Comment}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Window>